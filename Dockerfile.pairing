FROM node:20-slim

RUN apt-get update && apt-get install -y \
    libvips-dev \
    python3 make g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json ./
RUN npm install --omit=dev

COPY . .

RUN mkdir -p temp/pair-sessions media public

EXPOSE 3000

# Run the pairing server instead of the bot
CMD ["node", "pair.js"]
